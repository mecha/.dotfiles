{
  "layer": "top",
  "position": "top",
  "spacing": 5,
  "reload_style_on_change": true,
  "modules-left": [
    "cpu",
    "memory",
    "battery",
    "backlight",
    "custom/updates",
    "custom/face"
  ],
  "modules-center": [
      "hyprland/workspaces"
  ],
  "modules-right": [
    "mpris",
    "tray",
    "pulseaudio",
    "custom/notification",
    "clock"
  ],
  "cpu": {
    "interval": 5,
    "format": "пЛЫ {usage:2}%",
    "on-click": "ghostty -e btop"
  },
  "memory": {
    "interval": 5,
    "format": "оњЕ {:-2}%"
  },
  "disk": {
    "interval": 5,
    "format": "пИ≥ {percentage_used:2}%",
    "path": "/"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "у∞ГЮ",
      "у∞ГЯ",
      "у∞ГЭ",
      "у∞Г†"
    ]
  },
  "clock": {
    "format": "{:%a %d %h %H:%M}",
    "tooltip": false,
    "on-click": "ghostty -e ~/dev/personal/calren/calren"
  },
  "bluetooth": {
    "format": "пКУ",
    "format-disabled": "пКФ",
    "format-connected": "у∞В±",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager"
  },
  "pulseaudio": {
    "format": "{icon} {volume:3}%",
    "format-bluetooth": "{icon} {volume:3}%пКФ",
    "format-muted": "ої® ---%",
    "format-icons": {
      "headphones": "пА•",
      "default": [
        "пАІ",
        "пА®"
      ]
    },
    "scroll-step": 1,
    "smooth-scrolling-threshold": 1.5,
    "reverse-scrolling": true,
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute 0 toggle"
  },
  "battery": {
    "interval": 1,
    "states": {
      "good": 75,
      "mid": 50,
      "low": 25,
      "critical": 15
    },
    "format": "{icon} {capacity:2}%",
    "format-plugged": "у∞Ъ• {capacity}%",
    "format-full": " Full",
    "format-icons": {
      "default": [
        "у∞ВО",
        "у∞БЇ",
        "у∞Бї",
        "у∞БЉ",
        "у∞Бљ",
        "у∞БЊ",
        "у∞Бњ",
        "у∞ВА",
        "у∞ВБ",
        "у∞ВВ",
        "у∞Бє"
      ],
      "charging": [
        "у∞ҐЯ",
        "у∞ҐЬ",
        "у∞ВЖ",
        "у∞ВЗ",
        "у∞ВИ",
        "у∞ҐЭ",
        "у∞ВЙ",
        "у∞ҐЮ",
        "у∞ВК",
        "у∞ВЛ",
        "у∞ВЕ"
      ]
    }
  },
  "mpris": {
    "format": "{status_icon} оШ° {player_icon} {title} оШ° {artist}",
    "title-len": 18,
    "artist-len": 16,
    "player-icons": {
      "default": "рЯОµ",
      "firefox": "у∞Иє"
    },
    "status-icons": {
      "playing": "пБМ",
      "paused": "пБЛ",
      "stopped": "пБН"
    }
  },
  "tray": {
    "icon-size": 20,
    "spacing": 5,
    "show-passive-items": false,
    "reverse-direction": true
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "пВҐ",
      "none": "пВҐ",
      "dnd-notification": "пЗЈ",
      "dnd-none": "пЗЈ",
      "inhibited-notification": "пВҐ",
      "inhibited-none": "пВҐ",
      "dnd-inhibited-notification": "пЗЈ",
      "dnd-inhibited-none": "пЗЈ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/updates": {
    "format": "{icon} {0}",
    "format-updated": "Up to date",
    "return-type": "json",
    "format-icons": {
        "has-updates": "пАЩ",
        "updated": ""
    },
    "hide-empty-text": true,
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 600 --no-zero-output",
    "on-click": "ghostty -e bash -c 'echo \"=> FULL SYSTEM UPDATE\" && paru && echo \"=> SYSTEM UPDATED\" && read -n 1'",
    "on-click-right": "xdg-open https://archlinux.org/news"
  },
  "custom/face": {
    "exec": "/home/miguel/dev/personal/waybar-stuff/waysock listen",
    "on-click": "killall -SIGUSR1 mecha-face",
    "on-click-right": "killall -SIGUSR2 mecha-face",
    "format": "{}"
  }
}
